# Copy to .env and fill in. Never commit the real .env.

# Claude API key (for the daily narrative + web-search headlines)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token from BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-...

# Where to send the infographic. Any of:
#   - your personal chat id, e.g. 123456789  (DM the bot first, then run tools/get_chat_id.py)
#   - a public channel,      e.g. @my_market_channel
#   - a private channel,     e.g. -1001234567890   (bot must be an admin)
TELEGRAM_CHAT_ID=123456789

# WhatsApp Cloud API (Meta) — the image is also broadcast here every run.
# From your Meta app's WhatsApp panel (developers.facebook.com):
#   - a temporary or long-lived access token
WHATSAPP_ACCESS_TOKEN=EAAG...
#   - the sender's phone number id (NOT the phone number itself)
WHATSAPP_PHONE_NUMBER_ID=123456789012345
# Where to send it: your number in E.164 form, digits only, no '+', e.g. 6591234567.
# For freeform (non-template) sends, message the WhatsApp number first to open the 24h window.
WHATSAPP_RECIPIENT=6591234567

# Optional: agent name shown on the infographic (defaults to a placeholder)
AGENT_NAME=Jane Doe, Financial Services
